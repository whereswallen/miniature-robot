<%- include('layout', { title: 'Subscribers', page: 'subscribers', body: `
<div class="page-header">
  <h1>Subscribers</h1>
  <button class="btn btn-primary" onclick="showAddModal()">+ Add Subscriber</button>
</div>
<div class="filters-row">
  <input type="text" id="search-input" placeholder="Search name, username, phone..." class="input">
  <select id="status-filter" class="input">
    <option value="all">All Status</option>
    <option value="active">Active</option>
    <option value="disabled">Disabled</option>
    <option value="expired">Expired</option>
  </select>
  <select id="panel-filter" class="input">
    <option value="">All Panels</option>
  </select>
</div>
<div class="bulk-toolbar" id="bulk-toolbar" style="display:none">
  <span id="selected-count">0 selected</span>
  <button class="btn btn-sm btn-danger" onclick="bulkAction('disable')">Kill Selected</button>
  <button class="btn btn-sm btn-success" onclick="bulkAction('enable')">Enable Selected</button>
  <button class="btn btn-sm btn-primary" onclick="bulkExtendPrompt()">Extend Selected</button>
</div>
<div class="card">
  <table class="table" id="subs-table">
    <thead>
      <tr>
        <th><input type="checkbox" id="select-all" onchange="toggleSelectAll(this)"></th>
        <th class="sortable" data-sort="customer_name">Name</th>
        <th class="sortable" data-sort="xtream_username">Username</th>
        <th class="sortable" data-sort="package">Package</th>
        <th class="sortable" data-sort="expiry_date">Expiry</th>
        <th class="sortable" data-sort="status">Status</th>
        <th>Panel</th>
        <th class="sortable" data-sort="balance">Balance</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody></tbody>
  </table>
  <div class="pagination" id="pagination"></div>
</div>

<div class="modal" id="add-modal">
  <div class="modal-content">
    <div class="modal-header"><h3>Add Subscriber</h3><button class="modal-close" onclick="closeModal('add-modal')">&times;</button></div>
    <form id="add-form">
      <div class="form-row">
        <div class="form-group"><label>Customer Name *</label><input name="customerName" required class="input"></div>
        <div class="form-group"><label>Phone</label><input name="phone" class="input"></div>
      </div>
      <div class="form-row">
        <div class="form-group"><label>Telegram</label><input name="telegramUser" class="input"></div>
        <div class="form-group"><label>Panel</label><select name="panelId" id="add-panel-select" class="input"></select></div>
      </div>
      <div class="form-row">
        <div class="form-group"><label>Xtream Username *</label><input name="xtreamUsername" required class="input"></div>
        <div class="form-group"><label>Xtream Password *</label><input name="xtreamPassword" required class="input"></div>
      </div>
      <div class="form-row">
        <div class="form-group"><label>Package *</label><input name="pkg" required class="input" placeholder="e.g. 1 Month"></div>
        <div class="form-group"><label>Days</label><input name="days" type="number" value="30" class="input"></div>
      </div>
      <div class="form-row">
        <div class="form-group"><label>Max Connections</label><input name="maxConnections" type="number" value="1" class="input"></div>
        <div class="form-group"><label>Bouquet IDs</label><input name="bouquet" class="input" placeholder="comma-separated"></div>
      </div>
      <div class="form-group"><label>Notes</label><textarea name="notes" class="input"></textarea></div>
      <div class="form-actions">
        <button type="button" class="btn btn-outline" onclick="closeModal('add-modal')">Cancel</button>
        <button type="submit" class="btn btn-primary">Create Subscriber</button>
      </div>
    </form>
  </div>
</div>

<div class="modal" id="extend-modal">
  <div class="modal-content">
    <div class="modal-header"><h3>Extend Subscription</h3><button class="modal-close" onclick="closeModal('extend-modal')">&times;</button></div>
    <form id="extend-form">
      <input type="hidden" name="id" id="extend-id">
      <div class="form-group"><label>Days to extend</label><input name="days" type="number" value="30" class="input" required></div>
      <div class="form-actions">
        <button type="button" class="btn btn-outline" onclick="closeModal('extend-modal')">Cancel</button>
        <button type="submit" class="btn btn-primary">Extend</button>
      </div>
    </form>
  </div>
</div>

<script src="/js/subscribers.js"></script>
` }) %>
