<%- include('layout', { title: 'Subscriber Detail', page: 'subscribers', body: `
<div class="page-header">
  <h1 id="sub-title">Loading...</h1>
  <a href="/subscribers" class="btn btn-outline">Back to List</a>
</div>
<div class="detail-grid">
  <div class="card" id="info-card">
    <h3>Subscriber Info</h3>
    <div id="sub-info">Loading...</div>
    <div class="action-row" id="action-row"></div>
  </div>
  <div class="card">
    <h3>Quick Actions</h3>
    <div class="action-buttons" id="quick-actions"></div>
    <h3 style="margin-top:1rem">Record Payment</h3>
    <form id="payment-form">
      <div class="form-row">
        <div class="form-group"><label>Amount</label><input name="amount" type="number" step="0.01" class="input" required></div>
        <div class="form-group"><label>Method</label><select name="method" class="input"><option>Cash</option><option>Bank Transfer</option><option>Crypto</option><option>Other</option></select></div>
      </div>
      <div class="form-group"><label>Notes</label><input name="notes" class="input"></div>
      <button type="submit" class="btn btn-primary btn-sm">Record Payment</button>
    </form>
  </div>
</div>
<div class="card">
  <h3>Payment History</h3>
  <table class="table" id="payments-table">
    <thead><tr><th>Date</th><th>Amount</th><th>Type</th><th>Method</th><th>Balance After</th><th>Notes</th></tr></thead>
    <tbody></tbody>
  </table>
</div>
<div class="card">
  <h3>Audit Log</h3>
  <table class="table" id="audit-table">
    <thead><tr><th>Date</th><th>Action</th><th>Details</th></tr></thead>
    <tbody></tbody>
  </table>
</div>
<script>const SUBSCRIBER_ID = ${subscriberId};</script>
<script src="/js/subscriber-detail.js"></script>
` }) %>
