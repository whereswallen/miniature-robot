<%- include('layout', { title: 'Settings', page: 'settings', body: `
<h1>Settings</h1>
<div class="settings-grid">
  <div class="card">
    <h3>Panels</h3>
    <table class="table" id="panels-table">
      <thead><tr><th>Name</th><th>URL</th><th>Default</th><th>Status</th><th>Actions</th></tr></thead>
      <tbody></tbody>
    </table>
    <button class="btn btn-primary btn-sm" onclick="showPanelModal()">+ Add Panel</button>
  </div>
  <div class="card">
    <h3>Admin Accounts</h3>
    <table class="table" id="admins-table">
      <thead><tr><th>Username</th><th>Display Name</th><th>Actions</th></tr></thead>
      <tbody></tbody>
    </table>
    <button class="btn btn-primary btn-sm" onclick="showAdminModal()">+ Add Admin</button>
  </div>
  <div class="card">
    <h3>Alert Configuration</h3>
    <form id="alert-form">
      <div class="form-group"><label>Reminder Days (comma-separated)</label><input name="alert_days" class="input" id="alert-days" placeholder="1,3,7"></div>
      <div class="form-group"><label>Cron Schedule</label><input name="alert_cron" class="input" id="alert-cron" placeholder="0 9 * * *"></div>
      <button type="submit" class="btn btn-primary btn-sm">Save</button>
    </form>
  </div>
  <div class="card" style="grid-column: 1 / -1">
    <h3>Backups</h3>
    <div class="stat-cards" id="backup-stats" style="margin-bottom:1rem"></div>
    <div class="form-row" style="margin-bottom:1rem">
      <input type="text" id="backup-label" class="input" placeholder="Backup label (optional)" style="max-width:250px">
      <button class="btn btn-primary" onclick="createBackup()">Create Backup Now</button>
      <a href="/api/settings/backup" class="btn btn-outline">Quick Download (live DB)</a>
    </div>
    <table class="table" id="backups-table">
      <thead><tr><th>Filename</th><th>Label</th><th>Size</th><th>Created</th><th>Actions</th></tr></thead>
      <tbody></tbody>
    </table>
  </div>
</div>

<div class="modal" id="panel-modal">
  <div class="modal-content">
    <div class="modal-header"><h3 id="panel-modal-title">Add Panel</h3><button class="modal-close" onclick="closeModal('panel-modal')">&times;</button></div>
    <form id="panel-form">
      <input type="hidden" name="id" id="panel-id">
      <div class="form-group"><label>Name *</label><input name="name" required class="input"></div>
      <div class="form-group"><label>URL *</label><input name="url" required class="input" placeholder="http://panel:port"></div>
      <div class="form-group"><label>Username *</label><input name="username" required class="input"></div>
      <div class="form-group"><label>Password *</label><input name="password" required class="input"></div>
      <div class="form-group"><label><input type="checkbox" name="isDefault"> Set as Default</label></div>
      <div class="form-actions">
        <button type="button" class="btn btn-outline" onclick="closeModal('panel-modal')">Cancel</button>
        <button type="submit" class="btn btn-primary">Save</button>
      </div>
    </form>
  </div>
</div>

<div class="modal" id="admin-modal">
  <div class="modal-content">
    <div class="modal-header"><h3>Add Admin</h3><button class="modal-close" onclick="closeModal('admin-modal')">&times;</button></div>
    <form id="admin-form">
      <div class="form-group"><label>Username *</label><input name="username" required class="input"></div>
      <div class="form-group"><label>Password *</label><input name="password" required class="input" type="password"></div>
      <div class="form-group"><label>Display Name</label><input name="displayName" class="input"></div>
      <div class="form-actions">
        <button type="button" class="btn btn-outline" onclick="closeModal('admin-modal')">Cancel</button>
        <button type="submit" class="btn btn-primary">Create</button>
      </div>
    </form>
  </div>
</div>
<script src="/js/settings.js"></script>
` }) %>
