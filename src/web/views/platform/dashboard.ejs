<%- include('../partials/sidebar', { page: 'platform', role }) %>
<div class="content-area">
  <h1>Platform Dashboard</h1>
  <div class="stats-grid" id="platform-stats">
    <div class="stat-card"><div class="stat-value" id="stat-tenants">-</div><div class="stat-label">Total Tenants</div></div>
    <div class="stat-card"><div class="stat-value" id="stat-active">-</div><div class="stat-label">Active Tenants</div></div>
    <div class="stat-card"><div class="stat-value" id="stat-subscribers">-</div><div class="stat-label">Total Subscribers</div></div>
    <div class="stat-card"><div class="stat-value" id="stat-revenue">-</div><div class="stat-label">Total Revenue</div></div>
  </div>
</div>
<script>
  async function loadStats() {
    try {
      const res = await fetch('/api/platform/stats');
      const data = await res.json();
      document.getElementById('stat-tenants').textContent = data.tenants.total;
      document.getElementById('stat-active').textContent = data.tenants.active;
      document.getElementById('stat-subscribers').textContent = data.subscribers;
      document.getElementById('stat-revenue').textContent = '$' + data.revenue.toFixed(2);
    } catch (err) {
      console.error('Failed to load stats:', err);
    }
  }
  loadStats();
</script>
