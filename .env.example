# Xtream UI Reseller Credentials
XTREAM_PANEL_URL=http://your-panel-url.com:port
XTREAM_RESELLER_USERNAME=your_reseller_username
XTREAM_RESELLER_PASSWORD=your_reseller_password

# Telegram Bot
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_AUTHORIZED_CHAT_IDS=123456789,987654321

# Scheduler (cron expression - default 9 AM daily)
ALERT_CRON_SCHEDULE=0 9 * * *
ALERT_DAYS_BEFORE=1,3,7

# Database
DB_PATH=./data/access_killer.db
