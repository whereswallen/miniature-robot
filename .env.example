# Xtream UI Reseller Credentials (optional — panels managed in dashboard)
XTREAM_PANEL_URL=http://your-panel-url.com:port
XTREAM_RESELLER_USERNAME=your_reseller_username
XTREAM_RESELLER_PASSWORD=your_reseller_password

# Telegram Bot Tokens (optional — managed per-tenant in dashboard)
TELEGRAM_BOT_TOKEN=
TELEGRAM_AUTHORIZED_CHAT_IDS=
CUSTOMER_BOT_TOKEN=

# Web Dashboard
WEB_PORT=3000
WEB_SECRET=your-jwt-secret-change-this
WEB_ADMIN_USER=admin
WEB_ADMIN_PASS=admin

# Scheduler
ALERT_CRON_SCHEDULE=0 9 * * *
ALERT_DAYS_BEFORE=1,3,7
BACKUP_CRON_SCHEDULE=0 2 * * *

# Database
DB_PATH=./data/linetrack.db

# Stripe (optional — for automated billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
